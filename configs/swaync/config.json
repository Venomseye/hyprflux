{
    "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/main/src/configSchema.json",

    "positionX":                 "right",
    "positionY":                 "top",
    "layer":                     "overlay",
    "cssPriority":               "application",

    "timeout":                   5,
    "timeout-low":               3,
    "timeout-critical":          0,

    "fit-to-screen":             false,
    "control-center-width":      400,
    "control-center-height":     600,
    "control-center-margin-top": 58,
    "control-center-margin-bottom": 0,
    "control-center-margin-right":  12,
    "control-center-margin-left":   0,

    "notification-icon-size":    48,
    "notification-body-image-height": 150,
    "notification-body-image-width":  340,

    "widgets": [
        "title",
        "dnd",
        "notifications",
        "mpris"
    ],

    "widget-config": {
        "title": {
            "text":              "Notifications",
            "clear-all-button":  true,
            "button-text":       "  Clear All"
        },
        "dnd": {
            "text":              "Do Not Disturb"
        },
        "notifications": {
            "state-icons": {
                "no-notifications":        "󰍥",
                "dnd-notification":        "",
                "dnd-no-notifications":    ""
            }
        },
        "mpris": {
            "image-size":   56,
            "blur":         true
        }
    }
}
