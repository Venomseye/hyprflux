{
    "$schema": "https://raw.githubusercontent.com/ErikReider/SwayNotificationCenter/main/src/configSchema.json",

    "positionX": "right",
    "positionY": "top",

    "timeout": 5,
    "timeout-low": 3,
    "timeout-critical": 0,

    "fit-to-screen": false,
    "control-center-width": 400,
    "control-center-height": 620,
    "control-center-margin-top": 58,
    "control-center-margin-bottom": 0,
    "control-center-margin-right": 12,
    "control-center-margin-left": 0,

    "notification-icon-size": 48,
    "notification-body-image-height": 150,
    "notification-body-image-width": 340,

    "notification-visibility": {
        "example-name": {
            "state": "muted",
            "urgency": "Low",
            "app-name": "Spotify"
        }
    },

    "widgets": [
        "title",
        "dnd",
        "notifications",
        "mpris",
        "volume",
        "backlight",
        "inhibitors"
    ],

    "widget-config": {
        "title": {
            "text": "Notification Center",
            "clear-all-button": true,
            "button-text": "  Clear All"
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "notifications": {
            "state-icons": {
                "no-notifications": "󰍥",
                "dnd-notification": "",
                "dnd-no-notifications": ""
            }
        },
        "mpris": {
            "image-size": 56,
            "blur": true
        },
        "volume": {
            "label": "󰕾",
            "show-per-app": false
        },
        "backlight": {
            "label": "󰃠"
        },
        "inhibitors": {
            "text": "Inhibitors",
            "button-text": "Clear All",
            "active-label": "󰌪",
            "inactive-label": "󰌩"
        }
    }
}
